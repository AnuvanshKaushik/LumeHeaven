PORT=5000
MONGO_URI=mongodb://127.0.0.1:27017/lumeheaven
JWT_SECRET=replace_with_a_strong_secret
CLIENT_URL=http://localhost:5173
DEFAULT_MANAGER_EMAIL=manager@lumeheaven.com
DEFAULT_MANAGER_PASSWORD=Manager@123
DEFAULT_MANAGER_NAME=LUMEHEAVEN Manager

# Mail configuration (required for newsletter/order emails)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=youremail@gmail.com
EMAIL_PASS=your_app_password
EMAIL_FROM=LUMEHEAVEN <youremail@gmail.com>
# Optional aliases supported by the app:
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_FROM=LUMEHEAVEN <youremail@gmail.com>
# SMTP_SERVICE=gmail

# Google OAuth (Passport)
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:5000/auth/google/callback
SESSION_SECRET=replace_with_a_long_random_session_secret
